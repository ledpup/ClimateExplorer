@using Blazorise
@using ClimateExplorer.Web.Client.Components.Notifications

<!-- this div is necessary to get Blazor to apply a randomly-generated attribute to a DOM element so that CSS isolation will work & we can 
     style the navbar's inner elements https://github.com/Megabit/Blazorise/issues/1599 -->
<div>
    <Bar Breakpoint="Breakpoint.Desktop"
         Background="Background.Dark"
         ThemeContrast="ThemeContrast.Dark">
        <BarBrand>
            <BarLink To="">
                <div class="logo">
                    <img src="/logo-50.png" width="42" height="42" alt="ClimateExplorer" />
                </div>
            </BarLink>
        </BarBrand>
        <BarMenu>
            <BarStart>
                @foreach (var item in primaryItems)
                {
                    <BarItem>
                        <BarLink To="@item.Route" Class="@(IsCurrentPage(item.Route) ? "nav-current" : string.Empty)">@item.Text</BarLink>
                    </BarItem>
                }
                @foreach (var item in VisibleSecondaryItems)
                {
                    <BarItem Class="desktop-secondary-nav-item">
                        @if (item.OpensSiteOverview)
                        {
                            <button class="nav-link nav-button info-nav-link" aria-label="Site overview" @onclick="() => SiteOverviewService!.RequestShow()">
                                <i class="fas fa-circle-info"></i>
                            </button>
                        }
                        else
                        {
                            <BarLink To="@item.Route" Class="@(IsCurrentPage(item.Route!) ? "nav-current" : string.Empty)">@item.Text</BarLink>
                        }
                    </BarItem>
                }
                <BarItem Class="notification-nav-item">
                    <NotificationBell />
                </BarItem>
                <BarItem Class="mobile-menu-nav-item">
                    <Dropdown>
                        <DropdownToggle Class="@("hamburger-toggle" + (IsHamburgerCurrentPage() ? " nav-current" : string.Empty))" aria-label="More navigation options">
                            <i class="fas fa-bars" aria-hidden="true"></i>
                        </DropdownToggle>
                        <DropdownMenu>
                            @foreach (var item in VisibleSecondaryItems)
                            {
                                if (item.OpensSiteOverview)
                                {
                                    <button class="dropdown-item info-menu-item" aria-label="Site overview" @onclick="() => SiteOverviewService!.RequestShow()">
                                        <i class="fas fa-circle-info"></i> @item.Text
                                    </button>
                                }
                                else
                                {
                                    <a class="@("dropdown-item" + (IsCurrentPage(item.Route!) ? " hamburger-current" : string.Empty))" href="@item.Route">@item.Text</a>
                                }
                            }
                        </DropdownMenu>
                    </Dropdown>
                </BarItem>
            </BarStart>
        </BarMenu>
    </Bar>
</div>
