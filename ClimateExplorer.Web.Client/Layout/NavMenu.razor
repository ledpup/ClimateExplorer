@using Blazorise
@using ClimateExplorer.Web.Services
@inject ISiteOverviewService SiteOverviewService
@inject NavigationManager NavigationManager
@implements IDisposable

<!-- this div is necessary to get Blazor to apply a randomly-generated attribute to a DOM element so that CSS isolation will work & we can 
     style the navbar's inner elements https://github.com/Megabit/Blazorise/issues/1599 -->
<div>
    <Bar Breakpoint="Breakpoint.Desktop"
         Background="Background.Dark"
         ThemeContrast="ThemeContrast.Dark">
        <BarBrand>
            <BarLink To="">
                <div class="logo">
                    <img src="/logo-50.png" width="45" alt="ClimateExplorer" />
                    <span class="tooltip-content">
                        ClimateExplorer
                    </span>
                </div>
            </BarLink>
        </BarBrand>
        <BarMenu>
            <BarStart>
                <BarItem>
                    <BarLink To="">local</BarLink>
                </BarItem>
                <BarItem>
                    <BarLink To="regionalandglobal">regional &amp; global</BarLink>
                </BarItem>
                <BarItem>
                    <BarLink To="about">about</BarLink>
                </BarItem>
                <BarItem>
                    <BarLink To="blog" Target="Target.Blank">blog</BarLink>
                </BarItem>
                @{
                    var uri = NavigationManager!.ToAbsoluteUri(NavigationManager.Uri);
                    if (NavigationManager.Uri == NavigationManager.BaseUri || uri.LocalPath.StartsWith("/location"))
                    {
                        <BarItem>
                            <span class="info-icon">
                                <i class="fas fa-circle-info" @onclick="() => SiteOverviewService.RequestShow()"></i>
                            </span>
                        </BarItem>
                    }
                }
            </BarStart>
        </BarMenu>
    </Bar>
</div>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}