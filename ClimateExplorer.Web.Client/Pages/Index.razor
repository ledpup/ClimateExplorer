@page "/"
@page "/location/"
@page "/location/{locationString}"
@implements IDisposable

@using Blazorise
@using Blazorise.Snackbar
@using ClimateExplorer.Core.DataPreparation
@using static ClimateExplorer.Web.UiModel.SuggestedPresetLists;
@using static ClimateExplorer.Web.Client.Shared.Collapsible;
@using ClimateExplorer.Web.Client.Shared
@using ClimateExplorer.Web.Client.Shared.LocationComponents;

@inherits ChartablePage

<PageTitle>@PageTitle</PageTitle>

<HeadContent>
    <meta property="og:title" content="@PageTitle" />
    <meta property="og:url" content="@PageUrl" />
    <link rel="canonical" href="@PageUrl" />
</HeadContent>

<SnackbarStack @ref="Snackbar" Location="SnackbarStackLocation.Top" Interval="20000" Multiline="true" />

<Collapsible @ref="suggestedChartsCollapsible" InitiallyShown="false" ShowTitleWhenExpanded="false" ContentLayoutType="CollapserContentLayoutTypes.FlexboxRow">
    <CollapsedContent>
        @if (!suggestedChartsCollapsible!.ShowContent)
        {
            if (IsMobileDevice == true)
            {
                <SuggestedCharts DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" ExpandUpwards="false" PresetType="PresetTypes.MobileLocation" />
            }
            else
            {
                <SuggestedChartsMini DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" OnClickCollapser="@suggestedChartsCollapsible.CollapserOnClick" />
            }
        }
    </CollapsedContent>
    <Content>
        <SuggestedCharts DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" ExpandUpwards="false" PresetType="PresetTypes.Location" />
    </Content>
</Collapsible>

<div class="location-and-chart-container">
    <div style="position: relative;">
        <div class="map-space-reserver" id="mapContainerContainer">
            <MapContainer
                Locations="@LocationDictionary?.Values"
                OnLocationChange="@SelectedLocationChanged"
                Location="@Location" />
        </div>

        <div class="location-info-container">
            <LocationInfo Location="@Location"
                        DataSetDefinitions="@DataSetDefinitions"
                        RequestLocationChange="@ShowChangeLocationModal"
                        OnOverviewShowOrHide="@OnOverviewShowHide"
                        OnYearFilterChange="@HandleOnYearFilterChange" />
        </div>

        <div style="clear: both;"></div>
    </div>

    <ChartView @ref="ChartView"
               PageName="@PageName"
               DataSetDefinitions="@DataSetDefinitions"
               LocationDictionary="@LocationDictionary"
               Regions="@Regions"
               LocationId="@Location?.Id"
               ShowAddDataSetModalEvent="@ShowAddDataSetModal"
               DownloadDataEvent="@OnDownloadDataClicked"
               SnackbarMessageEvent="@SnackbarMessageEventHandler" />
</div>

<ChangeLocation @ref="ChangeLocationModal"
                LocationDictionary="@LocationDictionary"
                SelectedLocation="@Location"
                OnLocationChange="@SelectedLocationChanged"
                BrowserLocationErrorMessage="@BrowserLocationErrorMessage" />

<InfoPanel PanelName="home-overview" Version="1.0" Title="Welcome to ClimateExplorer">
    <p>
        ClimateExplorer is a website to help people understand climate change. It is focussed on trying to provide a simple interface for people to explore the changes to climate in their region.
        Select a location on the map or click <span class="chart-controls"><a class="chart-control" @onclick="ShowChangeLocationModal"><i class="fas fa-map"></i> Change location</a></span> to see historical temperature, rainfall, and other climate data from around the world, visualised as interactive charts.
    </p>
    <p>There are two main sections of the website; this page and the <a href="regionalandglobal">regional & global</a> section.</p>
    <p>
        Use the suggested charts to get started quickly, or add your own data sets to build custom views. The chevron (>) is there to expand/collapse parts of the site such as the suggested charts. <a href="#" @onclick="suggestedChartsCollapsible!.CollapserOnClick">Click the ></a> to see more options.
    </p>
</InfoPanel>

<Modal @ref="AddDataSetModal">
    <ModalContent>
        <ModalHeader Background="Background.Light">
            <ModalTitle>Add data set</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <DataSetBrowser DataSetDefinitions="@DataSetDefinitions" OnAddDataSet="@OnAddDataSet" CurrentLocation="@Location"></DataSetBrowser>
        </ModalBody>
    </ModalContent>
</Modal>