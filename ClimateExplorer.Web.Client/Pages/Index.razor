@page "/"
@page "/location/"
@page "/location/{locationString}"
@implements IDisposable

@using Blazorise
@using Blazorise.Snackbar
@using ClimateExplorer.Core.DataPreparation
@using static ClimateExplorer.Web.UiModel.SuggestedPresetLists;
@using static ClimateExplorer.Web.Client.Components.Common.Collapsible;
@using ClimateExplorer.Web.Client.Components
@using ClimateExplorer.Web.Client.Components.Chart
@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.Client.Components.Location
@using ClimateExplorer.Web.Client.Services.Chart

@inherits ChartablePage

<PageTitle>@PageTitle</PageTitle>

<HeadContent>
    <meta name="description" content="@PageDescription" />
    <meta property="og:title" content="@PageTitle" />
    <meta property="og:description" content="@PageDescription" />
    <meta property="og:url" content="@PageUrl" />
    <link rel="canonical" href="@PageUrl" />
</HeadContent>

<SnackbarStack @ref="SnackbarStack" Location="SnackbarStackLocation.Top" DefaultInterval="ChartablePage.SnackbarDisplayMs" TextAlignment="TextAlignment.Center" Class="snackbar-centre" />

<Collapsible @ref="suggestedChartsCollapsible" InitiallyShowContents="false" ShowTitleWhenExpanded="false" ContentLayoutType="CollapserContentLayoutTypes.FlexboxRow">
    <CollapsedContent>
        @if (!suggestedChartsCollapsible!.ShowContent)
        {
            <div class="suggested-mini-only">
                <SuggestedChartsMini DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" OnClickCollapser="@ToggleSuggestedCharts" />
            </div>
            <div class="suggested-mobile-only">
                <SuggestedCharts DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" ExpandUpwards="false" PresetType="PresetTypes.MobileLocation" />
            </div>
        }
    </CollapsedContent>
    <Content>
        <SuggestedCharts DataSetDefinitions="@DataSetDefinitions" SelectedLocation="@Location" OnChartPresetSelected="@OnChartPresetSelected" ExpandUpwards="false" PresetType="PresetTypes.Location" />
    </Content>
</Collapsible>

<div class="location-and-chart-container">
    <div style="position: relative;">
        <div class="map-space-reserver" id="mapContainerContainer">
            <MapContainer
                Locations="@MapLocations"
                OnLocationChange="@SelectedLocationChanged"
                Location="@Location" />
        </div>

        <div class="location-info-container">
            <LocationDashboard @ref="locationInfoComponent" Location="@Location"
                        DataSetDefinitions="@DataSetDefinitions"
                        RequestLocationChange="@ShowChangeLocationModal"
                        OnOverviewShowOrHide="@OnOverviewShowHide"
                        OnYearFilterChange="@HandleOnYearFilterChange" />
        </div>

        <div style="clear: both;"></div>
    </div>

    <ChartView @ref="ChartView"
               PageName="@PageName"
               InitialChartState="@InitialChartState"
               DataSetDefinitions="@DataSetDefinitions"
               ShowAddDataSetModalEvent="@ShowAddDataSetModal"
               DownloadDataEvent="@OnDownloadDataClicked"
               SnackbarMessageEvent="@SnackbarMessageEventHandler" />
</div>

<ChangeLocation @ref="ChangeLocationModal"
                LocationDictionary="@LocationDictionary"
                SelectedLocation="@Location"
                OnLocationChange="@SelectedLocationChanged"
                BrowserLocationErrorMessage="@BrowserLocationErrorMessage" />

<InfoPanel @ref="siteOverviewPanel" PanelName="home-overview" Version="1.1" Title="Welcome to ClimateExplorer" Height="22vh" MobileHeight="40vh">
    <HomeOverviewInfo OnAddDataSet="ShowAddDataSetModal"
                      OnToggleSuggestedCharts="ToggleSuggestedCharts"
                      OnShowRecordHigh="ShowRecordHighAsync" />
</InfoPanel>

<Modal @ref="AddDataSetModal">
    <ModalContent>
        <ModalHeader Class="custom-modal-header">
            <ModalTitle>Add data set</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <DataSetBrowser DataSetDefinitions="@DataSetDefinitions" OnAddDataSet="@OnAddDataSet" CurrentLocation="@Location" PreviousLocation="@PreviousLocation"></DataSetBrowser>
        </ModalBody>
    </ModalContent>
</Modal>
