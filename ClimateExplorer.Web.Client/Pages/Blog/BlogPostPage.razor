@page "/blog/{slug}"
@attribute [ExcludeFromInteractiveRouting]
@inject IBlogService BlogService

@if (post is null)
{
    <PageTitle>Post not found – ClimateExplorer</PageTitle>
    <div class="text-content">
        <h1>Post not found</h1>
        <p>The blog post you are looking for does not exist.</p>
        <a href="/blog">← Back to blog</a>
    </div>
}
else
{
    <PageTitle>@post.Title – ClimateExplorer</PageTitle>
    <HeadContent>
        <meta name="description" content="@post.Excerpt" />
        <link rel="canonical" href="https://climateexplorer.net/blog/@post.Slug" />
        <meta property="og:title" content="@post.Title" />
        <meta property="og:url" content="https://climateexplorer.net/blog/@post.Slug" />
        <meta property="og:type" content="article" />
        <meta property="og:site_name" content="ClimateExplorer" />
        @if (!string.IsNullOrEmpty(post.Excerpt))
        {
            <meta property="og:description" content="@post.Excerpt" />
        }
    </HeadContent>

    <div class="text-content">
        <div class="post-meta">
            <time datetime="@post.Date.ToString("yyyy-MM-dd")">@post.Date.ToString("d MMMM yyyy")</time>
            @if (!string.IsNullOrEmpty(post.Category))
            {
                <span class="post-category">@post.Category</span>
            }
        </div>
        <h1>@post.Title</h1>
        <article class="post-body">
            @((MarkupString)post.HtmlContent)
        </article>
        <div class="back-link">
            <a href="/blog">← Back to blog</a>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private BlogPost? post;

    protected override void OnParametersSet()
    {
        post = Slug is null ? null : BlogService.GetPostBySlug(Slug);
    }
}
