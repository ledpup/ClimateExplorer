@namespace ClimateExplorer.Web.Client.Components.Location
@using ClimateExplorer.Web.Client.UiModel

<article class="latest-record-tile @ToneClass">
    <div class="latest-record-period">@Tile.PeriodTitle</div>
    <h3>@Tile.Headline</h3>
    <p class="latest-record-percentile">@Tile.PercentileSentence</p>
    <div class="latest-record-primary">
        <span>@Tile.PrimaryLabel</span>
        <strong>@Tile.PrimaryValue</strong>
    </div>
    @if (Tile.Stats.Count > 0)
    {
        <dl class="latest-record-stats">
            @foreach (var stat in Tile.Stats)
            {
                <div>
                    <dt>@stat.Label</dt>
                    <dd>@stat.Value</dd>
                </div>
            }
        </dl>
    }
    @if (!string.IsNullOrWhiteSpace(Tile.Note))
    {
        <p class="latest-record-note">@Tile.Note</p>
    }
</article>

@code {
    [Parameter]
    [EditorRequired]
    public LatestRecordTileViewModel Tile { get; set; } = default!;

    private string ToneClass => Tile.Tone switch
    {
        LatestRecordTileTone.TemperatureWarm => "temperature-warm",
        LatestRecordTileTone.TemperatureCool => "temperature-cool",
        LatestRecordTileTone.PrecipitationWet => "precipitation-wet",
        LatestRecordTileTone.PrecipitationDry => "precipitation-dry",
        LatestRecordTileTone.Unavailable => "unavailable",
        _ => "neutral",
    };
}
