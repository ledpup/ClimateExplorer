@namespace ClimateExplorer.Web.Client.Components.Location
@using ClimateExplorer.Web.Client.UiModel
@inject IJSRuntime JsRuntime

<div class="hottest100-view mt-3">
    <svg @ref="svgRef" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 330" preserveAspectRatio="xMidYMid meet" style="width: 100%; height: auto; display: block;">
        <rect width="1200" height="330" fill="#ffffff"/>
        <text x="600" y="22" text-anchor="middle" font-size="16" font-weight="bold" fill="#333">@Title</text>
        <g transform="translate(0,30)">
            @((MarkupString)Hottest100.GenerateSvg(YearCounts, StartYear, EndYear))
        </g>
    </svg>
    <div class="hottest100-actions">
        <button class="hottest100-btn" @onclick="CopyAsImage"><i class="fas fa-copy"></i> Copy</button>
        <button class="hottest100-btn" @onclick="DownloadImage"><i class="fas fa-download"></i> Download</button>
    </div>
</div>

@code {
    [Parameter] public List<Hottest100.RecordCount> YearCounts { get; set; } = [];
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public int StartYear { get; set; }
    [Parameter] public int EndYear { get; set; }

    private ElementReference svgRef;

    private async Task CopyAsImage() =>
        await JsRuntime.InvokeVoidAsync("svgToImageCopy", svgRef);

    private async Task DownloadImage()
    {
        var fileName = Title.Replace(" ", "-").Replace("/", "-").ToLowerInvariant() + ".png";
        await JsRuntime.InvokeVoidAsync("svgToImageDownload", svgRef, fileName);
    }
}
