@using Blazorise
@using Blazorise.LoadingIndicator
@using ClimateExplorer.Core
@using ClimateExplorer.Core.DataPreparation
@using ClimateExplorer.Core.Model
@using ClimateExplorer.Core.ViewModel
@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.Client.Services
@using ClimateExplorer.Web.Client.UiModel
@using ClimateExplorer.Web.UiModel
@using System.Globalization
@using ClimateExplorer.Web.Client.Components
@using ClimateExplorer.Web.Client.Components.Info
@using ClimateExplorer.WebApiClient.Services
@using static ClimateExplorer.Core.Enums
@using Microsoft.Extensions.Logging

<div class="d-flex align-items-center justify-content-between mb-4">
    <Tabs SelectedTab="@ActiveView.ToString()" SelectedTabChanged="@OnViewChanged">
        <Items>
            <Tab Name="Top100">Top 100</Tab>
            <Tab Name="Daily">Daily</Tab>
            <Tab Name="Monthly">Monthly</Tab>
            <Tab Name="Yearly">Yearly</Tab>
        </Items>
    </Tabs>
</div>

<div class="filter-row">
@if (AvailableDataTypes.Count > 0 && SelectedDataType is not null)
{
    <Tooltip Text="Select the type of climate data to view records for">
        <Select TValue="DataType"
                Value="@SelectedDataType.Value"
                ValueChanged="@OnDataTypeChanged"
                Size="Size.Small">
            @foreach (var dt in AvailableDataTypes.OrderBy(x => x))
            {
                <SelectItem Value="@dt">@ChartSeriesDefinition.MapDataTypeToFriendlyName(dt)</SelectItem>
            }
        </Select>
    </Tooltip>
    @if (ActiveView == RecordView.Daily || ActiveView == RecordView.Monthly || ActiveView == RecordView.Top100)
    {
        <Tooltip Text="Filter records to a specific month, or view all months">
            <Select TValue="int"
                    Value="@SelectedMonth"
                    ValueChanged="@OnMonthChanged"
                    Size="Size.Small">
                <SelectItem Value="0">All months</SelectItem>
                @for (int m = 1; m <= 12; m++)
                {
                    var monthNum = m;
                    <SelectItem Value="@monthNum">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(monthNum)</SelectItem>
                }
            </Select>
        </Tooltip>
    }
    @if (AvailableDataAdjustments.Count > 1)
    {
        <Tooltip Text="By using data from nearby stations, adjusted temperatures are corrected for non-climatic influences such as station relocations and instrument changes. Uncheck to see raw, unmodified measurements.">
            <label class="adjusted-check">
                <input type="checkbox" class="adjusted-input"
                       checked="@(SelectedDataAdjustment == DataAdjustment.Adjusted)"
                       @onchange="@(async (ChangeEventArgs e) => await OnAdjustedChanged((bool)e.Value!))" />
                Adjusted
            </label>
        </Tooltip>
    }
    <Tooltip Text="Toggle sort order">
        <button class="sort-toggle-btn" @onclick="OnSortToggled">
            <i class="fa-solid fa-temperature-arrow-@(Ascending ? "up" : "down")"></i> @SortLabel
        </button>
    </Tooltip>
}
</div>
@if (ActiveView != RecordView.Top100)
{
    <DelayedLoadingIndicator @bind-Visible="@LoadingIndicatorVisible">
        <div class="table-card">
            <div class="table-header">
                <span>@Location?.Name - @RecordsTitle@(SelectedMonth == 0 ? string.Empty : " - " + CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(SelectedMonth))</span>
            </div>
            @if (ClimateRecordsResult?.Records is { Count: > 0 })
            {
                <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>#</Strong></TableHeaderCell>
                            <TableHeaderCell Class="colour-col"></TableHeaderCell>
                            @if (ActiveView == RecordView.Yearly)
                            {
                                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Year</Strong></TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End"><Strong>Anomaly</Strong></TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End" @onclick="OnSortToggled" Style="cursor: pointer; user-select: none;"><Strong>Average <i class="fas @SortIcon"></i></Strong></TableHeaderCell>
                            }
                            else
                            {
                                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>@(ActiveView == RecordView.Monthly ? "Month" : "Day month")</Strong></TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Year</Strong></TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End" @onclick="OnSortToggled" Style="cursor: pointer; user-select: none;"><Strong>@(ActiveView == RecordView.Monthly ? "Average" : "Value") <i class="fas @SortIcon"></i></Strong></TableHeaderCell>
                            }
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @{
                            var rank = ((CurrentPage - 1) * Count) + 1;
                            foreach (var (record, rowStyle) in ClimateRecordsResult!.Records.Zip(ComputedRowStyles))
                            {
                                var currentRank = rank;
                                <tr>
                                    <td class="text-center">@currentRank</td>
                                    <td class="colour-col" style="@rowStyle"></td>
                                    @if (ActiveView == RecordView.Yearly)
                                    {
                                        <td>@record.Year</td>
                                        <td class="text-end">@(record.Anomaly.HasValue ? FormatAnomaly(record.Anomaly.Value, record.UnitOfMeasure) : "N/A")</td>
                                        <td class="text-end">@(record.Average.HasValue ? FormatValue(record.Average.Value, record.UnitOfMeasure) : "N/A")</td>
                                    }
                                    else
                                    {
                                        <td>
                                            @if (record.Day.HasValue)
                                            {
                                                <span class="secondary-text">@record.Day @CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(record.Month)</span>
                                            }
                                            else
                                            {
                                                <span class="secondary-text">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(record.Month)</span>
                                            }
                                        </td>
                                        <td>@record.Year</td>
                                        <td class="text-end">@FormatValue(record.Value, record.UnitOfMeasure)</td>
                                    }
                                </tr>
                                rank++;
                            }
                        }
                    </TableBody>
                </Table>
            }
            else if (ClimateRecordsResult is null && LoadingIndicatorVisible)
            {
                <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>#</Strong></TableHeaderCell>
                            <TableHeaderCell Class="colour-col"></TableHeaderCell>
                            @if (ActiveView == RecordView.Yearly)
                            {
                                <TableHeaderCell TextAlignment="TextAlignment.Center">Year</TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End">Anomaly</TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End" @onclick="OnSortToggled" Style="cursor: pointer; user-select: none;"><Strong>Average <i class="fas @SortIcon"></i></Strong></TableHeaderCell>
                            }
                            else
                            {
                                <TableHeaderCell TextAlignment="TextAlignment.Center">@(ActiveView == RecordView.Monthly ? "Month" : "Day month")</TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.Center">Year</TableHeaderCell>
                                <TableHeaderCell TextAlignment="TextAlignment.End" @onclick="OnSortToggled" Style="cursor: pointer; user-select: none;">@(ActiveView == RecordView.Monthly ? "Average" : "Value") <i class="fas @SortIcon"></i></TableHeaderCell>
                            }
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @for (int i = 0; i < Count; i++)
                        {
                            <tr><td>&nbsp;</td><td></td><td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td></tr>
                        }
                    </TableBody>
                </Table>
            }
            else
            {
                <p>No records found for the selected filters.</p>
            }
            @if (ClimateRecordsResult?.Records is { Count: > 0 })
            {
                <div class="table-footer">
                    <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-2">
                        <div class="d-flex flex-wrap align-items-center justify-content-center gap-4">
                            <PaginationControl TotalPages="@TotalPages"
                            CurrentPage="@CurrentPage"
                            PageChanged="@OnPageChanged" />
                            <div class="d-flex align-items-center gap-1">
                                <Tooltip Text="Number of records per page">
                                    <Select TValue="int"
                                    Value="@Count"
                                    ValueChanged="@OnCountChanged"
                                    Size="Size.Small">
                                        <SelectItem Value="10">10</SelectItem>
                                        <SelectItem Value="20">20</SelectItem>
                                        <SelectItem Value="50">50</SelectItem>
                                    </Select>
                                </Tooltip>
                            </div>
                        </div>
                        <span class="text-muted">@StartRecord-@EndRecord of @(ClimateRecordsResult.TotalCount)</span>
                    </div>
                </div>
            }
        </div>
        @if (ClimateRecordsResult?.Records is { Count: > 0 })
        {
            <div class="d-flex justify-content-end mt-2">
                <button class="subtle-link" @onclick="DownloadAllRecords"><i class="fas fa-download"></i> Download</button>
            </div>
        }
        </DelayedLoadingIndicator>
}

@if (ActiveView == RecordView.Top100)
{
    <Hottest100 Location="@Location"
    DataType="@SelectedDataType"
    DataAdjustment="@SelectedDataAdjustment"
    Ascending="@Ascending"
    SelectedMonth="@SelectedMonth" />
}
else
{
    <h3>Cell colour</h3>
    <p>The colour of each cell indicates the relative age of the record within the dataset.</p>
    <ul>
        <li><b>Green</b> marks a recent record.</li>
        <li><b>Near-white</b> indicates records from the middle of the dataset.</li>
        <li><b>Grey</b> highlights an early record.</li>
    </ul>
    <p>When a dataset shows no clear trend, we expect to see records from anywhere in the time series. If the table is dominated by green cells, that is an indication of a warming trend; a table dominated by grey cells suggests cooling.</p>
}