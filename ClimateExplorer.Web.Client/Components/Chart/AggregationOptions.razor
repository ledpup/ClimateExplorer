@using Blazorise
@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.Client.Components.Info
@using ClimateExplorer.Web.Client.UiModel

<div class="aggregation-options-wrapper">
    @if (panelOpen)
    {
        <div class="aggregation-options-backdrop" @onclick="ClosePanel"></div>
    }
    <div class="aggregation-options-container">
        <DelayedTooltip Text="Change how data is grouped for aggregation.<br>Group fortnightly at a 70% threshold by default">
            <button class="chart-control aggregation-toggle dropdown-toggle" @onclick="TogglePanel">
                <i class="fas fa-cog"></i> Aggregation
            </button>
        </DelayedTooltip>
        @if (panelOpen)
        {
            <div class="aggregation-options-panel">
                <div class="aggregation-options-content">
                    <DelayedTooltip Text="Number of days used to group data points into a single bin" Style="display: block">
                        <div class="form-row">
                            <span class="form-label">Grouping days</span>
                            <span class="form-control-wrap">
                                <Select TValue="short" Value="@currentGroupingDays" ValueChanged="@OnSelectedGroupingDaysChanged">
                                    <SelectItem Value="182">@AggregationSettings.GroupingDaysText(182)</SelectItem>
                                    <SelectItem Value="91">@AggregationSettings.GroupingDaysText(91)</SelectItem>
                                    <SelectItem Value="28">@AggregationSettings.GroupingDaysText(28)</SelectItem>
                                    <SelectItem Value="14">@AggregationSettings.GroupingDaysText(14)</SelectItem>
                                    <SelectItem Value="7">@AggregationSettings.GroupingDaysText(7)</SelectItem>
                                </Select>
                            </span>
                        </div>
                    </DelayedTooltip>
                    <DelayedTooltip Text="Minimum percentage of days with valid data required for a bin to be included in the chart" Style="display: block">
                        <div class="form-row">
                            <span class="form-label">Threshold (%)</span>
                            <span class="form-control-wrap">
                                <input type="number" class="form-control form-control-sm" min="0" max="100" step="10"
                                       value="@thresholdValue" @oninput="OnThresholdChanged" />
                            </span>
                        </div>
                    </DelayedTooltip>
                    <DelayedTooltip Text="When checked, your custom threshold is used instead of the dataset's recommended preset" Style="display: block">
                        <div class="form-row">
                            <span class="form-control-wrap">
                                <Check TValue="bool" Value="@overridePresetThreshold" ValueChanged="@((bool v) => OnOverrideChanged(v))">Override preset threshold</Check>
                            </span>
                        </div>
                    </DelayedTooltip>
                    <div class="form-row form-row-actions">
                        <DelayedTooltip Text="Reset aggregation options to their defaults">
                            <Button Color="Color.Primary" Size="Size.Small" Clicked="@ResetThreshold" Disabled="@(!HaveOptionsChanged)">Reset</Button>
                        </DelayedTooltip>
                        <i class="fas fa-circle-info info-icon" @onclick="ShowAggregationOptionsInfo"></i>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<InfoPanel @ref="aggregationOptionsInfoPanel" Title="Aggregation options" Height="50vh" MobileHeight="60vh">
    <AggregationOptionsInfo />
</InfoPanel>
