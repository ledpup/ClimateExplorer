@using Blazorise

<Dropdown>
    <DropdownToggle Class="@CssClass" aria-label="@EffectiveAriaLabel" @attributes="AdditionalAttributes">
        @if (!string.IsNullOrWhiteSpace(Icon))
        {
            <i class="@Icon" aria-hidden="true"></i>
        }
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @Text
        }
    </DropdownToggle>
    <DropdownMenu>
        @MenuContent
    </DropdownMenu>
</Dropdown>
