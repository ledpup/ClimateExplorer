@namespace ClimateExplorer.Web.Client.Components.RecentObservations
@using ClimateExplorer.Web.Client.UiModel.RecentObservations

@foreach (var section in Sections)
{
    <h4 class="trends-stat-section-title">@section.Title</h4>
    <dl class="trends-stat-table">
        @foreach (var row in section.Rows)
        {
            <div class="trends-stat-row @(row.IsEmphasized ? "emphasized" : string.Empty)">
                <dt>@row.Label</dt>
                <dd>
                    <span class="trends-stat-value">@row.Value</span>
                    @if (row.HasExplanation)
                    {
                        <button type="button"
                                class="trends-stat-expand"
                                aria-expanded="@(IsExpanded(section, row) ? "true" : "false")"
                                aria-label="@($"About {row.Label}")"
                                @onclick="@(() => ToggleExpanded(section, row))">
                            <span class="oi oi-chevron-right recent-observation-chevron @(IsExpanded(section, row) ? "expanded" : string.Empty)" aria-hidden="true"></span>
                        </button>
                    }
                </dd>
            </div>
            @if (row.HasExplanation && IsExpanded(section, row))
            {
                <div class="trends-stat-explanation">
                    @if (!string.IsNullOrWhiteSpace(row.AbstractExplanation))
                    {
                        <p>@row.AbstractExplanation</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(row.ClimateExplanation))
                    {
                        <p>@row.ClimateExplanation</p>
                    }
                    @if (row.WorkedExamples is { Count: > 0 } workedExamples)
                    {
                        <ul class="trends-stat-worked-examples">
                            @foreach (var example in workedExamples)
                            {
                                <li>@example</li>
                            }
                        </ul>
                    }
                </div>
            }
        }
    </dl>
}

@code {
    private readonly HashSet<(string SectionTitle, string RowLabel)> expandedRows = [];

    [Parameter]
    [EditorRequired]
    public IReadOnlyList<TrendStatSection> Sections { get; set; } = [];

    private bool IsExpanded(TrendStatSection section, TrendStatRow row) => expandedRows.Contains((section.Title, row.Label));

    private void ToggleExpanded(TrendStatSection section, TrendStatRow row)
    {
        if (!expandedRows.Add((section.Title, row.Label)))
        {
            expandedRows.Remove((section.Title, row.Label));
        }
    }
}
