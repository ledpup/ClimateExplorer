@namespace ClimateExplorer.Web.Client.Components.RecentObservations

<dl class="recent-observation-detail-metrics">
    @foreach (var metric in Metrics)
    {
        <div class="recent-observation-detail-metric">
            <dt>@metric.Label</dt>
            <dd>
                @if (!string.IsNullOrWhiteSpace(metric.UnavailableReason))
                {
                    <span class="recent-observation-detail-record">@metric.UnavailableReason</span>
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace(metric.HeadlineText))
                    {
                        <DelayedTooltip Text="@metric.FullPeriodTooltip" Multiline="true">
                            <div class="recent-observation-detail-headline">
                                <span class="recent-observation-detail-current @ValueClassifier.GetValueClass(metric.HeadlineText, metric.IsHeadlinePositive)">@metric.HeadlineText</span>
                                <span class="recent-observation-detail-rank">full period</span>
                            </div>
                        </DelayedTooltip>
                    }
                    @if (!string.IsNullOrWhiteSpace(metric.RecentTrendValueText))
                    {
                        <DelayedTooltip Text="@metric.RecentTrendTooltip" Multiline="true">
                            <span class="recent-observation-detail-record">Last 30 years: <span class="@ValueClassifier.GetValueClass(metric.RecentTrendValueText, metric.IsRecentTrendPositive)">@metric.RecentTrendValueText</span></span>
                        </DelayedTooltip>
                    }
                    @if (!string.IsNullOrWhiteSpace(metric.FirstHalfTrendValueText))
                    {
                        <DelayedTooltip Text="@metric.FirstHalfTrendTooltip" Multiline="true">
                            <span class="recent-observation-detail-record">Early period: <span class="@ValueClassifier.GetValueClass(metric.FirstHalfTrendValueText, metric.IsFirstHalfTrendPositive)">@metric.FirstHalfTrendValueText</span></span>
                        </DelayedTooltip>
                    }
                }
            </dd>
        </div>
    }
    <div class="recent-observation-detail-metric recent-observation-trend-about">
        <TrendsAboutButton OnClick="@ShowAboutTrends" />
    </div>
</dl>
<AboutTrends @ref="aboutTrends" Metrics="@Metrics" DownloadRequested="@OnDownloadRequested" />
