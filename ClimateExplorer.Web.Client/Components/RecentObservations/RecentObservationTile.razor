@namespace ClimateExplorer.Web.Client.Components.RecentObservations
@using ClimateExplorer.Web.Client.UiModel.RecentObservations

<article class="recent-observation-tile @ToneClass @RemovableClass @ExpandableClass">
    <RecentObservationMainPanel Tile="@Tile"
                                Expansion="@Expansion"
                                IsRemovable="@IsRemovable"
                                RemoveButtonLabel="@RemoveButtonLabel"
                                OnRemove="@OnRemove"
                                OnExpansionChanged="@OnExpansionChanged" />

    @if (Expansion.IsExpanded && Tile.AvailableExpandedTabs.Count > 0)
    {
        <div class="recent-observation-detail">
            @if (Tile.AvailableExpandedTabs.Count > 1)
            {
                <div class="recent-observation-detail-toggle" role="group" aria-label="Statistics view">
                    @foreach (var tab in Tile.AvailableExpandedTabs)
                    {
                        <button type="button"
                                class="recent-observation-detail-toggle-option @(Expansion.IsGroupSelected(tab.Key) ? "selected" : string.Empty)"
                                aria-pressed="@(Expansion.IsGroupSelected(tab.Key) ? "true" : "false")"
                                @onclick="@(() => Expansion.SelectGroup(tab.Key))">
                            @tab.Title
                        </button>
                    }
                </div>
            }

            @if (SelectedTab is RecentObservationRecordsTabViewModel recordsTab)
            {
                @if (IsDayRecordsSelected)
                {
                    <RecentObservationDayRecords Metrics="@recordsTab.Metrics" />
                }
                else
                {
                    <RecentObservationPeriodRecords Metrics="@recordsTab.Metrics" />
                }
            }
            else if (SelectedTab is RecentObservationVariationTabViewModel variationTab)
            {
                <RecentObservationVariations Metrics="@variationTab.Metrics" />
            }
            else if (SelectedTab is RecentObservationTrendTabViewModel trendTab)
            {
                <RecentObservationTrend Metrics="@trendTab.Metrics" />
            }
        </div>
    }
</article>
