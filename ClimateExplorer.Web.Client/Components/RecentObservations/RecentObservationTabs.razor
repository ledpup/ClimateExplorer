@namespace ClimateExplorer.Web.Client.Components.Location
@using Blazorise
@using ClimateExplorer.Web.Client.UiModel.RecentObservations

<div class="climate-tabs recent-observation-tabs">
    <Tabs SelectedTab="@SelectedTab.ToString()" SelectedTabChanged="@OnSelectedTabChanged">
        <Items>
            <Tab Name="@RecentObservationsTab.Temperature.ToString()">Temperature</Tab>
            <Tab Name="@RecentObservationsTab.Precipitation.ToString()">Precipitation</Tab>
        </Items>
    </Tabs>
</div>

@code {
    [Parameter]
    public RecentObservationsTab SelectedTab { get; set; }

    [Parameter]
    public EventCallback<RecentObservationsTab> SelectedTabChanged { get; set; }

    private async Task OnSelectedTabChanged(string selectedTab)
    {
        if (Enum.TryParse<RecentObservationsTab>(selectedTab, out var tab))
        {
            await SelectedTabChanged.InvokeAsync(tab);
        }
    }
}
