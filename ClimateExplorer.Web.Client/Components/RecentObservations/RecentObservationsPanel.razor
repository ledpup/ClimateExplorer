@namespace ClimateExplorer.Web.Client.Components.RecentObservations
@using Blazorise
@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.Client.Components.RecentObservations
@using ClimateExplorer.Web.Client.UiModel.RecentObservations
@using static ClimateExplorer.Core.Enums

<div class="recent-observations-panel">
    <RecentObservationTabs SelectedTab="@ActiveTab" SelectedTabChanged="@OnTabChanged" />

    <div class="recent-observations-body" aria-live="polite">
        @if (CurrentState.IsLoading)
        {
            <div class="recent-observations-state">
                <span><i class="fas fa-spinner fa-spin"></i> Loading recent observations...</span>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(CurrentState.ErrorMessage))
        {
            <div class="recent-observations-state error">
                <span><i class="fas fa-triangle-exclamation"></i> @CurrentState.ErrorMessage</span>
                <ClimateButton Text="Retry" Icon="fas fa-rotate-right" Class="recent-observations-retry" OnClick="RetryCurrentTab" />
            </div>
        }
        else
        {
            if (CurrentTiles.Count > 0)
            {
                <div class="chart-controls recent-observations-period-controls mb-4">
                    <ClimateButton Text="@AddDayButtonLabel" Disabled="@IsAddEarlierDayDisabled" OnClick="AddEarlierDay" />
                    <ClimateButton Text="@AddMonthButtonLabel" Disabled="@IsAddEarlierMonthDisabled" OnClick="AddEarlierMonth" />
                    <ClimateButton Text="@AddSeasonButtonLabel" Disabled="@IsAddEarlierSeasonDisabled" OnClick="AddEarlierSeason" />
                    <ClimateButton Text="@AddYearButtonLabel" Disabled="@IsAddEarlierYearDisabled" OnClick="AddEarlierYear" />

                    @if (ActiveTab == RecentObservationsTab.Temperature && AvailableDataAdjustments.Count > 1)
                    {
                        <DelayedTooltip Text="By using data from nearby stations, adjusted temperatures are corrected for non-climatic influences such as station relocations and instrument changes.<br>Uncheck to see raw, unmodified measurements." Multiline="true">
                            <label class="adjusted-check">
                                <input type="checkbox" class="adjusted-input"
                                       checked="@(SelectedDataAdjustment == DataAdjustment.Adjusted)"
                                       @onchange="@(async (ChangeEventArgs e) => await OnAdjustedChanged((bool)e.Value!))" />
                                Adjusted
                            </label>
                        </DelayedTooltip>
                    }

                    @if (HasExpandableCurrentTiles)
                    {
                        <ClimateButton Class="chart-control recent-observations-toggle-all"
                                       AriaLabel="@ExpandCollapseAllLabel"
                                       title="@ExpandCollapseAllLabel"
                                       OnClick="ToggleAllTileExpansion">
                            <span class="oi oi-chevron-right recent-observations-toggle-all-chevron @(AreAllExpandableCurrentTilesExpanded ? "expanded" : string.Empty)" aria-hidden="true"></span>
                            @ExpandCollapseAllLabel
                        </ClimateButton>
                    }
                </div>

                <div class="recent-observation-grid mb-4">
                    @foreach (var tile in TilesBeforeMonthControls)
                    {
                        <div class="recent-observation-tile-slot" @key="GetTileKey(tile)">
                            <RecentObservationTile Tile="@tile" Expansion="@GetTileExpansionState(tile)" IsRemovable="@IsRemovableTile(tile)" RemoveButtonLabel="@CreateRemoveTileLabel(tile)" OnRemove="@(() => RemoveTile(tile))" OnExpansionChanged="@OnTileExpansionChanged" />
                        </div>
                    }

                    @foreach (var tile in SeasonTiles)
                    {
                        <div class="recent-observation-tile-slot" @key="GetTileKey(tile)">
                            <RecentObservationTile Tile="@tile" Expansion="@GetTileExpansionState(tile)" IsRemovable="@IsRemovableTile(tile)" RemoveButtonLabel="@CreateRemoveTileLabel(tile)" OnRemove="@(() => RemoveTile(tile))" OnExpansionChanged="@OnTileExpansionChanged" />
                        </div>
                    }

                    @foreach (var tile in TilesAfterSeasonControls)
                    {
                        <div class="recent-observation-tile-slot" @key="GetTileKey(tile)">
                            <RecentObservationTile Tile="@tile" Expansion="@GetTileExpansionState(tile)" IsRemovable="@IsRemovableTile(tile)" RemoveButtonLabel="@CreateRemoveTileLabel(tile)" OnRemove="@(() => RemoveTile(tile))" OnExpansionChanged="@OnTileExpansionChanged" />
                        </div>
                    }
                </div>

                <div style="max-width: 1024px;">
                    <h3 class="mt-4 mb-3">Configuration</h3>
                    <div class="recent-observations-config-grid mb-3">
                        @if (CurrentState.Result?.ReferenceDate is not null)
                        {
                            <div class="recent-observations-config-field">
                                <DelayedTooltip Text="Set a custom reference date to view the most recent observations as of that date." Style="display: block">
                                    <div class="recent-observations-config-control recent-observations-reference-date-control">
                                        <label for="@ReferenceDateInputId">View as of</label>
                                        <input id="@ReferenceDateInputId"
                                            type="text"
                                            class="form-control form-control-sm @ReferenceDateInputValidationClass"
                                            placeholder="YYYY-MM-DD"
                                            value="@referenceDateInputValue"
                                            aria-describedby="@ReferenceDateHelpId"
                                            aria-invalid="@(!string.IsNullOrWhiteSpace(referenceDateValidationMessage))"
                                            @oninput="OnReferenceDateInput"
                                            @onchange="OnReferenceDateChanged" />
                                        <ClimateButton Icon="fas fa-rotate-left"
                                                        Class="recent-observations-reference-date-reset"
                                                        AriaLabel="Reset to latest reference date"
                                                        title="Reset to latest reference date"
                                                        Disabled="@IsResetReferenceDateDisabled"
                                                        OnClick="ResetReferenceDate" />
                                    </div>
                                </DelayedTooltip>
                                @if (!string.IsNullOrWhiteSpace(referenceDateValidationMessage))
                                {
                                    <div class="invalid-feedback d-block">@referenceDateValidationMessage</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(CurrentState.Result.ReferenceDateNote))
                                {
                                    <span class="recent-observations-reference-date-note">@CurrentState.Result.ReferenceDateNote</span>
                                }
                            </div>
                            <div class="recent-observations-config-field">
                                <DelayedTooltip Text="Choose whether comparisons use data available up until the selected reference date or the station's full record." Style="display: block">
                                    <div class="recent-observations-config-control">
                                        <label for="@ComparisonRangeInputId">Comparison range</label>
                                        <Select TValue="ComparisonEndMode"
                                                ElementId="@ComparisonRangeInputId"
                                                Value="@selectedComparisonEndMode"
                                                ValueChanged="@OnComparisonEndModeChanged"
                                                Size="Size.Small">
                                            <SelectItem Value="@ComparisonEndMode.FullDataset">Entire dataset</SelectItem>
                                            <SelectItem Value="@ComparisonEndMode.ReferenceDate">Up to view date</SelectItem>
                                        </Select>
                                    </div>
                                </DelayedTooltip>
                            </div>
                        }
                        <div class="recent-observations-config-field">
                            <DelayedTooltip Text="Historical comparisons are shown when sufficient data is available.<br />Completeness threshold sets the minimum percentage of observations required." Style="display: block">
                                <div class="recent-observations-config-control recent-observations-threshold">
                                    <label for="recent-observations-completeness-threshold">Completeness threshold %</label>
                                    <input id="recent-observations-completeness-threshold"
                                        type="number"
                                        class="form-control form-control-sm"
                                        min="@RecentObservationCompletenessThreshold.MinimumPercentage"
                                        max="@RecentObservationCompletenessThreshold.MaximumPercentage"
                                        step="1"
                                        value="@CompletenessThresholdPercent"
                                        @oninput="OnCompletenessThresholdChanged" />
                                </div>
                            </DelayedTooltip>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="recent-observations-state">
                    <i class="fas fa-circle-info"></i>
                    <span>@CurrentEmptyMessage</span>
                </div>
            }
        }
    </div>
</div>
