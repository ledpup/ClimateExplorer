@namespace ClimateExplorer.Web.Client.Components.Location
@using Blazorise
@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.Client.UiModel

<DelayedLoadingIndicator @bind-Visible="@IsLoading">
    <div class="top100-space">
    @if (YearCounts.Count > 0)
    {
        <div class="mt-3">
            <div class="top100-svg-container">
                <svg @ref="svgRef" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 @Top100Model.ChartWidth @Top100Model.ChartHeight" preserveAspectRatio="xMidYMid meet" class="top100-svg">
                    <rect width="@Top100Model.ChartWidth" height="@Top100Model.ChartHeight" fill="#ffffff" />
                    <text x="@(Top100Model.ChartWidth / 2)" y="22" text-anchor="middle" font-size="12" font-weight="bold" fill="#000">@BuildTitle()</text>
                    <g transform="translate(0,30)">
                        @((MarkupString)Top100Model.Generate(YearCounts, StartYear, EndYear))
                    </g>
                </svg>
            </div>
            <div class="top100-actions">
                <DelayedTooltip Text="Copy the chart as an image to the clipboard">
                    <ClimateButton Text="Copy" Icon="fas fa-copy" Class="top100-btn" OnClick="CopyAsImage" />
                </DelayedTooltip>
                <DelayedTooltip Text="Download the chart as a PNG or SVG file">
                    <div class="top100-download-dropdown-wrapper">
                        <DropdownButton Text="Download" Icon="fas fa-download">
                            <MenuContent>
                                <DropdownItem Clicked="DownloadImage">PNG</DropdownItem>
                                <DropdownItem Clicked="DownloadSvg">SVG</DropdownItem>
                            </MenuContent>
                        </DropdownButton>
                    </div>
                </DelayedTooltip>
            </div>
        </div>
    }
    </div>
</DelayedLoadingIndicator>

<h3>Top 100</h3>
<p>A barcode-like chart that shows how the top 100 daily records are distributed across years.</p>
<ul>
    <li>Each vertical bar represents a year that contributes at least one record to the top 100.</li>
    <li>A wider bar means more records from that year appear in the top 100.</li>
</ul>
<p>In a stable climate, bars would be spread evenly across the full record. Clustering towards recent years is a signal of a warming trend; clustering towards earlier years suggests cooling.</p>
