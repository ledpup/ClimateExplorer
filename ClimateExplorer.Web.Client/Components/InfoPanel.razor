@using ClimateExplorer.Web.Client.Services

@if (isVisible && isMobileDevice != null)
{
    <div class="info-panel-overlay" @onclick="DismissAsync">
        <div class="info-panel @(isAnimatingIn ? "slide-in" : "") @(isAnimatingOut ? "slide-out" : "")" data-panel-name="@PanelName"
             style="@(Height != null && !isMobileDevice.Value ? $"height: {Height}" : null)"
             @onclick:stopPropagation="true">
            <div class="info-panel-header">
                <h2>@Title</h2>
                <button class="info-panel-close" @onclick="DismissAsync" aria-label="Dismiss">✕</button>
            </div>
            <div class="info-panel-body">
                @ChildContent
            </div>
        </div>
    </div>
}