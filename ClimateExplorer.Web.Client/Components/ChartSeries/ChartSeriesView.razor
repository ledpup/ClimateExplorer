@using ClimateExplorer.Web.Client.Components.Common
@using ClimateExplorer.Web.UiLogic
@using ClimateExplorer.Web.UiModel
@using Blazorise
@using ClimateExplorer.Core.DataPreparation
@using static ClimateExplorer.Core.Enums;

<div class="chart-series-config @(ChartSeries!.IsExpanded ? "is-expanded" : "") @(TitleStyle == ChartSeriesTitleStyle.WholeTitleBarInSeriesColour ? "has-colour-strip" : "")" style="@StyleForOuterDiv">
    <div class="title-bar"
         role="button"
         tabindex="0"
         aria-label="@ToggleExpandedLabel"
         @onclick="ExpandCollapse"
         @onkeydown="OnTitleBarKeyDown"
         style="@StyleForTitleBar">
        <div class="main">
            <div class="title">@ChartSeries!.GetFriendlyTitleShort()</div>
            <div class="description">@ChartSeries!.GetFriendlyDescription()</div>
        </div>
        <div class="title-bar-actions">
            <DelayedTooltip Text="Remove this series">
                <button type="button" class="trash" aria-label="Remove this series" @onclick="@OnRemoveSeriesClicked" @onclick:stopPropagation="true">
                    <i class="fas fa-trash fa-lg"></i>
                </button>
            </DelayedTooltip>
            <div class="expander">
                <span class="@(ChartSeries!.IsExpanded ? "oi oi-chevron-top" : "oi oi-chevron-bottom")" aria-hidden="true"></span>
            </div>
        </div>
    </div>

    @if (ChartSeries.IsExpanded)
    {
        <div class="chart-series-config-content" style="@StyleForTitleBar">
            <div class="edit-form">
                <div class="edit-form-columns">
                    <div class="edit-col">
                        @if (ChartSeries.Year.HasValue)
                        {
                            <div class="form-row">
                                <span class="form-label">Filter to year</span>
                                <span class="form-control-wrap">@ChartSeries.Year</span>
                            </div>
                        }
                        <DelayedTooltip Text="How data values within each time period are combined into a single point" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Aggregation</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SeriesAggregationOptions"
                                            Size="Size.Small"
                                            Value="@ChartSeries.Aggregation"
                                            ValueChanged="@OnAggregationChanged"
                                            Disabled="@ShouldDisableAggregationOptions(ChartSeries)">
                                        <SelectItem Value="SeriesAggregationOptions.Mean">Mean</SelectItem>
                                        <SelectItem Value="SeriesAggregationOptions.Minimum">Minimum</SelectItem>
                                        <SelectItem Value="SeriesAggregationOptions.Maximum">Maximum</SelectItem>
                                        <SelectItem Value="SeriesAggregationOptions.Median">Median</SelectItem>
                                        <SelectItem Value="SeriesAggregationOptions.Sum">Sum</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        @if (ChartSeries.Smoothing != SeriesSmoothingOptions.None && !ChartSeries.BinGranularity.IsLinear())
                        {
                            <div class="form-row-info info-message">Note that smoothing is not currently being applied because the x-axis is not linear.</div>
                        }
                        <DelayedTooltip Text="An optional calculation applied on top of the primary aggregation" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Secondary calculation</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SecondaryCalculationOptions"
                                            Size="Size.Small"
                                            Value="@ChartSeries.SecondaryCalculation"
                                            ValueChanged="@OnSecondaryCalculationChanged">
                                        <SelectItem Value="SecondaryCalculationOptions.None">None</SelectItem>
                                        <SelectItem Value="SecondaryCalculationOptions.AnnualChange">Annual change</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Reduces noise by averaging values across a rolling window of periods" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Smoothing</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SeriesSmoothingOptions"
                                            Size="Size.Small"
                                            Value="@ChartSeries.Smoothing"
                                            ValueChanged="@OnSmoothingChanged">
                                        <SelectItem Value="SeriesSmoothingOptions.None">None</SelectItem>
                                        <SelectItem Value="SeriesSmoothingOptions.MovingAverage">Moving average</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Number of periods to include in the rolling average" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Smoothing window</span>
                                <span class="form-control-wrap">
                                    <Select TValue="int"
                                            Size="Size.Small"
                                            Value="@ChartSeries.SmoothingWindow"
                                            ValueChanged="@OnSmoothingWindowChanged"
                                            Disabled="@ShouldDisableSmoothingWindow(ChartSeries)">
                                        <SelectItem Value="3">3</SelectItem>
                                        <SelectItem Value="5">5</SelectItem>
                                        <SelectItem Value="7">7</SelectItem>
                                        <SelectItem Value="10">10</SelectItem>
                                        <SelectItem Value="12">12</SelectItem>
                                        <SelectItem Value="15">15</SelectItem>
                                        <SelectItem Value="20">20</SelectItem>
                                        <SelectItem Value="30">30</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                    </div>
                    <div class="edit-col">
                        <DelayedTooltip Text="Whether to plot actual values or the departure from the historical mean (anomaly)" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Display</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SeriesValueOptions"
                                            Size="Size.Small"
                                            Value="@ChartSeries.Value"
                                            ValueChanged="@OnValueChanged"
                                            Disabled="@ShouldDisableDisplay(ChartSeries)">
                                        <SelectItem Value="SeriesValueOptions.Value">Value</SelectItem>
                                        <SelectItem Value="SeriesValueOptions.Anomaly">Anomaly relative to mean</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="A mathematical transformation applied to each data value before plotting" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Transformation</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SeriesTransformations"
                                            Size="Size.Small"
                                            Value="@ChartSeries.SeriesTransformation"
                                            ValueChanged="@OnTransformationChanged"
                                            Disabled="@ShouldDisableTransformation(ChartSeries)">
                                        <SelectItem Value="SeriesTransformations.Identity">Identity</SelectItem>
                                        <SelectItem Value="SeriesTransformations.Negate">Negate</SelectItem>
                                        <SelectItem Value="SeriesTransformations.DayOfYearIfFrost">Day of year if frost</SelectItem>
                                        <SelectItem Value="SeriesTransformations.Custom">Custom</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        @if (ChartSeries.SeriesTransformation == SeriesTransformations.Custom)
                        {
                            <DelayedTooltip Text="A logical expression applied to each value (use x as the data value)" Style="display: block">
                                <div class="form-row">
                                    <span class="form-label">Custom expression</span>
                                    <span class="form-control-wrap">
                                        <Validation @ref="validation" Validator="ValidateCustomTransformation">
                                            <TextInput Value="@ChartSeries.CustomTransformation"
                                                       ValueChanged="@OnCustomTransformationChanged"
                                                       Placeholder="e.g. x == 0 or x >= 1 AND x < 10"
                                                       Immediate="false">
                                                <Feedback>
                                                    <ValidationError>Expected input like: 'x &gt; 25' or 'x &gt;= 1 AND x &lt; 10'</ValidationError>
                                                </Feedback>
                                            </TextInput>
                                        </Validation>
                                    </span>
                                </div>
                            </DelayedTooltip>
                        }
                        <DelayedTooltip Text="Whether to draw this series as a line or a bar chart" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Display style</span>
                                <span class="form-control-wrap">
                                    <Select TValue="SeriesDisplayStyle"
                                            Size="Size.Small"
                                            Value="@ChartSeries.DisplayStyle"
                                            ValueChanged="@OnDisplayStyleChanged">
                                        <SelectItem Value="SeriesDisplayStyle.Line">Line</SelectItem>
                                        <SelectItem Value="SeriesDisplayStyle.Bar">Bar</SelectItem>
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="The colour used to draw this series on the chart" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Colour</span>
                                <span class="form-control-wrap">
                                    <Select TValue="Colours"
                                            Size="Size.Small"
                                            Value="@ChartSeries.RequestedColour"
                                            ValueChanged="@OnColourChanged">
                                            @foreach (var colour in (Colours[])Enum.GetValues(typeof(Colours)))
                                            {
                                                <SelectItem Value="@colour">@GetColourName(colour)</SelectItem>
                                            }
                                    </Select>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Overlay a linear trendline on this series" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Show trendline</span>
                                <span class="form-control-wrap">
                                    <Check TValue="bool" Value="@ChartSeries.ShowTrendline" ValueChanged="@OnShowTrendlineChanged"></Check>
                                </span>
                            </div>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Prevent this series from being replaced when a new chart preset is selected" Style="display: block">
                            <div class="form-row">
                                <span class="form-label">Lock?</span>
                                <span class="form-control-wrap">
                                    <Check TValue="bool" Value="@ChartSeries.IsLocked" ValueChanged="@OnIsLockedChanged"></Check>
                                </span>
                            </div>
                        </DelayedTooltip>
                    </div>
                    <div class="series-controls">
                        <DelayedTooltip Text="About this data" Style="display: inline-block">
                            <button type="button" class="series-control" aria-label="About this data" @onclick="@OnAboutThisDataClicked">
                                <i class="fas fa-info"></i>
                                <div class="label">About</div>
                            </button>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Duplicate this series" Style="display: inline-block">
                            <button type="button" class="series-control" aria-label="Duplicate this series" @onclick="@OnDuplicateSeriesClicked">
                                <i class="fas fa-clone"></i>
                                <div class="label">Clone</div>
                            </button>
                        </DelayedTooltip>
                        <DelayedTooltip Text="Remove this series" Style="display: inline-block">
                            <button type="button" class="series-control danger" aria-label="Remove this series" @onclick="@OnRemoveSeriesClicked">
                                <i class="fas fa-trash"></i>
                                <div class="label">Remove</div>
                            </button>
                        </DelayedTooltip>
                    </div>
                </div>
            </div>

        </div>
    }
</div>

<AboutData @ref="aboutData" ChartSeries="@ChartSeries" SourceMetadata="@SourceMetadata" />
