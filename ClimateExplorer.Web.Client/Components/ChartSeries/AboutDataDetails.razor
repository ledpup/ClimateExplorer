@using ClimateExplorer.Core.Model
@using ClimateExplorer.Core.ViewModel

@if (DataSetDefinition is not null || Metadata is not null)
{
    <div class="entry">
        <div class="title">Dataset</div>
        <div class="value">
            @if (DataSetDefinition?.MoreInformationUrl != null)
            {
                <a href="@DataSetDefinition.MoreInformationUrl" target="_blank" rel="noopener noreferrer">@DataSetDefinition.Name</a>
            }
            else
            {
                @FormatMissing(DataSetDefinition?.Name ?? Metadata?.SourceName)
            }
        </div>
    </div>
    @if (DataSetDefinition?.Description != null)
    {
        <div class="entry">
            <div class="title">Description</div>
            <div class="value">@((MarkupString)DataSetDefinition.Description.Replace("\r\n", "<br>"))</div>
        </div>
    }

    @if (GetMeasurementDefinitions(DataSetDefinition) is { Count: > 0 } measurementDefinitions)
    {
        <div class="entry">
            <div class="title mb-2">Available data</div>
            <div class="table-card source-measurements">
                <table class="table">
                    <thead>
                        <tr>
                            <th class="data-type-col">Data type</th>
                            <th>Resolution</th>
                            <th>Unit</th>
                            <th>Adjustment</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var measurementDefinition in measurementDefinitions)
                        {
                            <tr>
                                <td class="data-type-col">@FormatDataType(measurementDefinition)</td>
                                <td>@FormatDataResolution(measurementDefinition)</td>
                                <td>@FormatUnitOfMeasure(measurementDefinition)</td>
                                <td>@FormatDataAdjustment(measurementDefinition)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (Metadata is not null && HasRenderableMetadata(Metadata))
    {
        if (HasRenderableStations(Metadata))
        {
            var showStationLinks = HasStationLinks(Metadata);
             <div class="entry">
                <div class="title mb-2">Stations</div>
                <div class="table-card source-stations">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Station ID</th>
                                <th class="station-name-col">Station name</th>
                                <th>Start date</th>
                                <th>End date</th>
                                @if (showStationLinks)
                                {
                                    <th>Source</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var station in Metadata.Stations)
                            {
                                <tr>
                                    <td>@FormatMissing(station.StationId)</td>
                                    <td class="station-name-col">@FormatMissing(station.StationName)</td>
                                    <td>@FormatDate(station.StationStartDate)</td>
                                    <td>@FormatDate(station.StationEndDate)</td>
                                    @if (showStationLinks)
                                    {
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(station.SourceUrl))
                                            {
                                                <a href="@station.SourceUrl" target="_blank" rel="noopener noreferrer">@FormatStationUrlLabel(station)</a>
                                            }
                                            else
                                            {
                                                <span>&#x2014;</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (!showStationLinks
                && !string.IsNullOrWhiteSpace(Metadata.SourceUrl)
                && DataSetDefinition?.MoreInformationUrl != Metadata.SourceUrl)
            {
                <div class="entry source-link">
                    <div class="title">Source link</div>
                    <div class="value">
                        <a href="@Metadata.SourceUrl" target="_blank" rel="noopener noreferrer">@FormatSourceUrlLabel(Metadata)</a>
                    </div>
                </div>
            }
        }
        else if (!string.IsNullOrWhiteSpace(Metadata.SourceUrl) && DataSetDefinition?.MoreInformationUrl != Metadata.SourceUrl)
        {
            <div class="entry">
                <div class="title">Source link</div>
                <div class="value">
                    <a href="@Metadata.SourceUrl" target="_blank" rel="noopener noreferrer">@FormatSourceUrlLabel(Metadata)</a>
                </div>
            </div>
        }

        @if (DataSetDefinition?.Publisher is not null)
        {
            <div class="entry">
                <div class="title">Published by</div>
                <div class="value">
                    <a href="@DataSetDefinition.PublisherUrl" target="_blank" rel="noopener noreferrer">@DataSetDefinition.Publisher</a>
                </div>
            </div>
        }
    }
}
