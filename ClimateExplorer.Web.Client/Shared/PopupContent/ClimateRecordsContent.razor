@using Blazorise
@using Blazorise.LoadingIndicator
@using ClimateExplorer.Core
@using ClimateExplorer.Core.DataPreparation
@using ClimateExplorer.Core.Model
@using ClimateExplorer.Core.ViewModel
@using ClimateExplorer.Web.Client.Services
@using ClimateExplorer.Web.Client.UiModel
@using ClimateExplorer.Web.UiModel
@using System.Globalization
@using ClimateExplorer.WebApiClient.Services
@using static ClimateExplorer.Core.Enums

<Tabs SelectedTab="@ActiveView.ToString()" SelectedTabChanged="@OnViewChanged" Class="mb-4">
    <Items>
        <Tab Name="Daily">Daily</Tab>
        <Tab Name="Monthly">Monthly</Tab>
        <Tab Name="Yearly">Yearly</Tab>
    </Items>
</Tabs>

@if (AvailableDataTypes.Count > 0)
{
    <Fields>
        <Field>
            <FieldLabel>Data type</FieldLabel>
            <FieldBody>
                <Select TValue="DataType"
                        Value="@SelectedDataType"
                        ValueChanged="@OnDataTypeChanged"
                        Size="Size.Small">
                    @foreach (var dt in AvailableDataTypes)
                    {
                        <SelectItem Value="@dt">@ChartSeriesDefinition.MapDataTypeToFriendlyName(dt)</SelectItem>
                    }
                </Select>
            </FieldBody>
        </Field>
        <Field>
            <FieldLabel>Order</FieldLabel>
            <FieldBody>
                <Select TValue="bool"
                        Value="@Ascending"
                        ValueChanged="@OnAscendingChanged"
                        Size="Size.Small">
                    <SelectItem Value="false">Highest first</SelectItem>
                    <SelectItem Value="true">Lowest first</SelectItem>
                </Select>
            </FieldBody>
        </Field>
        @if (ActiveView == RecordView.Daily || ActiveView == RecordView.Monthly)
        {
            <Field ColumnSize="ColumnSize.IsAuto">
                <FieldLabel>Month</FieldLabel>
                <FieldBody>
                    <Select TValue="int"
                            Value="@SelectedMonth"
                            ValueChanged="@OnMonthChanged"
                            Size="Size.Small">
                        <SelectItem Value="0">All months</SelectItem>
                        @for (int m = 1; m <= 12; m++)
                        {
                            var monthNum = m;
                            <SelectItem Value="@monthNum">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(monthNum)</SelectItem>
                        }
                    </Select>
                </FieldBody>
            </Field>
        }
        @if (AvailableDataAdjustments.Count > 1)
        {
            <Field ColumnSize="ColumnSize.IsAuto">
                <FieldLabel>Adjustment</FieldLabel>
                <FieldBody>
                    <Select TValue="string"
                            Value="@DataAdjustmentToString(SelectedDataAdjustment)"
                            ValueChanged="@OnDataAdjustmentStringChanged"
                            Size="Size.Small">
                        @foreach (var da in AvailableDataAdjustments)
                        {
                            <SelectItem Value="@DataAdjustmentToString(da)">@(da.HasValue? da.Value.ToString() : "None")</SelectItem>
                        }
                    </Select>
                </FieldBody>
            </Field>
        }
        <Field ColumnSize="ColumnSize.IsAuto">
            <FieldLabel>Count</FieldLabel>
            <FieldBody>
                <Select TValue="int"
                        Value="@Count"
                        ValueChanged="@OnCountChanged"
                        Size="Size.Small">
                    <SelectItem Value="10">10</SelectItem>
                    <SelectItem Value="20">20</SelectItem>
                    <SelectItem Value="50">50</SelectItem>
                </Select>
            </FieldBody>
        </Field>
    </Fields>
}
<LoadingIndicator @bind-Visible="@LoadingIndicatorVisible">
    @if (ActiveView == RecordView.Yearly)
    {
        @if (YearlyResult is { Count: > 0 })
        {
            <Table>
                <TableHeader>
                    <TableRow>
                        <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>#</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Year</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.End"><Strong>Anomaly</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.End"><Strong>Average</Strong></TableHeaderCell>
                    </TableRow>
                </TableHeader>
                <TableBody>
                    @{
                        var rank = 1;
                        foreach (var (record, rowStyle) in YearlyResult.Zip(ComputedRowStyles))
                        {
                            var currentRank = rank;
                            <tr>
                                <td class="text-center" style="@rowStyle">@currentRank</td>
                                <td style="@rowStyle">@record.Year</td>
                                <td class="text-end" style="@rowStyle">@FormatAnomaly(record.Relative, SelectedUnitOfMeasure)</td>
                                <td class="text-end" style="@rowStyle">@FormatValue(record.Absolute, SelectedUnitOfMeasure)</td>
                            </tr>
                            rank++;
                        }
                    }
                </TableBody>
            </Table>
        }
        else
        {
            <p>No yearly records found for the selected filters.</p>
        }
    }
    else
    {
        @if (ClimateRecordsResult?.Records is { Count: > 0 })
        {
            <Table>
                <TableHeader>
                    <TableRow>
                        <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>#</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>@(ActiveView == RecordView.Monthly ? "Month" : "Day month")</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Year</Strong></TableHeaderCell>
                        <TableHeaderCell TextAlignment="TextAlignment.End"><Strong>Value</Strong></TableHeaderCell>
                    </TableRow>
                </TableHeader>
                <TableBody>
                    @{
                        var rank = 1;
                        foreach (var (record, rowStyle) in ClimateRecordsResult!.Records.Zip(ComputedRowStyles))
                        {
                            var currentRank = rank;
                            <tr>
                                <td class="text-center" style="@rowStyle">@currentRank</td>
                                <td style="@rowStyle">
                                    @if (record.Day.HasValue)
                                    {
                                        <span class="secondary-text">@record.Day @CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(record.Month)</span>
                                    }
                                    else
                                    {
                                        <span class="secondary-text">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(record.Month)</span>
                                    }
                                </td>
                                <td style="@rowStyle">@record.Year</td>
                                <td class="text-end" style="@rowStyle">@FormatValue(record.Value, record.UnitOfMeasure)</td>
                            </tr>
                            rank++;
                        }
                    }
                </TableBody>
            </Table>
        }
        else
        {
            <p>No records found for the selected filters.</p>
        }
    }
</LoadingIndicator>

@code {
    enum RecordView { Daily, Monthly, Yearly }

    [Inject]
    public IDataService? DataService { get; set; }

    [Parameter]
    public Location? Location { get; set; }

    [PersistentState]
    public ClimateRecordsResponse? ClimateRecordsResult { get; set; }

    bool LoadingIndicatorVisible { get; set; }

    List<DataType> AvailableDataTypes { get; set; } = [];
    List<DataAdjustment?> AvailableDataAdjustments { get; set; } = [];
    List<string> ComputedRowStyles { get; set; } = [];
    List<MeasurementDefinitionViewModel> LocationMeasurements { get; set; } = [];
    IEnumerable<DataSetDefinitionViewModel>? DataSetDefinitions { get; set; }

    DataType SelectedDataType { get; set; } = DataType.TempMax;
    DataAdjustment? SelectedDataAdjustment { get; set; } = DataAdjustment.Adjusted;
    UnitOfMeasure SelectedUnitOfMeasure { get; set; } = UnitOfMeasure.DegreesCelsius;
    int SelectedMonth { get; set; } = 0;
    bool Ascending { get; set; } = false;
    int Count { get; set; } = 10;
    RecordView ActiveView { get; set; } = RecordView.Daily;

    List<YearlyValues>? YearlyResult { get; set; }
    int? YearlyStartYear { get; set; }
    int? YearlyEndYear { get; set; }

    Guid? InternalLocationId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Location is null || Location.Id == InternalLocationId)
        {
            return;
        }

        InternalLocationId = Location.Id;
        await LoadAvailableOptions();
        await LoadRecords();
    }

    async Task LoadAvailableOptions()
    {
        DataSetDefinitions = await DataService!.GetDataSetDefinitions();
        LocationMeasurements = DataSetDefinitions
            .Where(x => x.LocationIds != null && x.LocationIds.Contains(Location!.Id))
            .SelectMany(x => x.MeasurementDefinitions!)
            .Where(x => x.DataResolution == DataResolution.Daily || x.DataResolution == DataResolution.Monthly)
            .ToList();

        AvailableDataTypes = LocationMeasurements
            .Select(x => x.DataType)
            .Distinct()
            .ToList();

        if (AvailableDataTypes.Contains(DataType.TempMax))
            SelectedDataType = DataType.TempMax;
        else if (AvailableDataTypes.Any())
            SelectedDataType = AvailableDataTypes.First();

        UpdateAvailableAdjustments();
    }

    void UpdateAvailableAdjustments()
    {
        AvailableDataAdjustments = LocationMeasurements
            .Where(x => x.DataType == SelectedDataType)
            .Select(x => x.DataAdjustment)
            .Distinct()
            .ToList();

        if (AvailableDataAdjustments.Contains(DataAdjustment.Adjusted))
            SelectedDataAdjustment = DataAdjustment.Adjusted;
        else if (AvailableDataAdjustments.Any())
            SelectedDataAdjustment = AvailableDataAdjustments.First();
        else
            SelectedDataAdjustment = null;

        var selectedMeasurement = LocationMeasurements.FirstOrDefault(x => x.DataType == SelectedDataType && x.DataAdjustment == SelectedDataAdjustment);
        SelectedUnitOfMeasure = selectedMeasurement?.UnitOfMeasure ?? UnitOfMeasure.DegreesCelsius;
    }

    async Task LoadRecords()
    {
        if (Location is null) return;

        LoadingIndicatorVisible = true;

        try
        {
            if (ActiveView == RecordView.Yearly)
            {
                await LoadYearlyRecords();
            }
            else
            {
                var month = SelectedMonth != 0 ? (int?)SelectedMonth : null;
                ClimateRecordsResult = await DataService!.GetClimateRecords(Location.Id, SelectedDataType, SelectedDataAdjustment, Ascending, Count, month, ActiveView == RecordView.Monthly);
                ComputedRowStyles = ComputeRowStyles(ClimateRecordsResult);
                YearlyResult = null;
            }
        }
        finally
        {
            LoadingIndicatorVisible = false;
        }
    }

    async Task LoadYearlyRecords()
    {
        if (DataSetDefinitions is null || Location is null) return;

        var dataSubstitutes = new List<DataSubstitute>
        {
            new() { DataType = SelectedDataType, DataAdjustment = SelectedDataAdjustment },
        };

        var fn = SelectedDataType == DataType.Precipitation ? ContainerAggregationFunctions.Sum : ContainerAggregationFunctions.Mean;
        var summary = await ClimateDataHelper.CalculateAnomaly(DataService!, DataSetDefinitions, Location, dataSubstitutes, fn);

        if (summary?.AnomalyRecords is not { Count: > 0 })
        {
            YearlyResult = summary is not null ? [] : null;
            ComputedRowStyles = [];
            ClimateRecordsResult = null;
            return;
        }

        YearlyStartYear = (int?)summary.AnomalyRecords.Min(x => (int)x.Year);
        YearlyEndYear = (int?)summary.AnomalyRecords.Max(x => (int)x.Year);
        var ordered = Ascending
            ? summary.AnomalyRecords.OrderBy(x => x.Absolute).Take(Count)
            : summary.AnomalyRecords.OrderByDescending(x => x.Absolute).Take(Count);
        YearlyResult = ordered.ToList();
        ComputedRowStyles = ComputeYearlyRowStyles(YearlyResult, YearlyStartYear, YearlyEndYear);
        ClimateRecordsResult = null;
    }

    async Task OnViewChanged(string name)
    {
        ActiveView = Enum.Parse<RecordView>(name);
        await LoadRecords();
    }

    async Task OnDataTypeChanged(DataType value)
    {
        SelectedDataType = value;
        UpdateAvailableAdjustments();
        await LoadRecords();
    }

    async Task OnDataAdjustmentStringChanged(string value)
    {
        SelectedDataAdjustment = value == "none" ? null : Enum.Parse<DataAdjustment>(value);
        await LoadRecords();
    }

    async Task OnMonthChanged(int value)
    {
        SelectedMonth = value;
        await LoadRecords();
    }

    async Task OnAscendingChanged(bool value)
    {
        Ascending = value;
        await LoadRecords();
    }

    async Task OnCountChanged(int value)
    {
        Count = value;
        await LoadRecords();
    }

    static List<string> ComputeRowStyles(ClimateRecordsResponse? response)
    {
        if (response is null) return [];
        if (response.StartYear is not int start || response.EndYear is not int end || end == start)
            return response.Records.Select(_ => string.Empty).ToList();
        return response.Records
            .Select(record =>
            {
                double recentness = Math.Clamp((double)(record.Year - start) / (end - start), 0, 1);
                int red, green, blue;
                if (recentness >= 0.5)
                {
                    double t = (recentness - 0.5) * 2;
                    red = 255;
                    green = blue = (int)(255 - 180 * t);
                }
                else
                {
                    double t = recentness * 2;
                    blue = 255;
                    red = green = (int)(75 + 180 * t);
                }
                return string.Format(System.Globalization.CultureInfo.InvariantCulture, "background-color: rgb({0}, {1}, {2}, .1)", red, green, blue);
            })
            .ToList();
    }

    static List<string> ComputeYearlyRowStyles(List<YearlyValues> records, int? startYear, int? endYear)
    {
        if (startYear is not int start || endYear is not int end || end == start)
            return records.Select(_ => string.Empty).ToList();
        return records
            .Select(record =>
            {
                double recentness = Math.Clamp((double)(record.Year - start) / (end - start), 0, 1);
                int red, green, blue;
                if (recentness >= 0.5)
                {
                    double t = (recentness - 0.5) * 2;
                    red = 255;
                    green = blue = (int)(255 - 180 * t);
                }
                else
                {
                    double t = recentness * 2;
                    blue = 255;
                    red = green = (int)(75 + 180 * t);
                }
                return string.Format(System.Globalization.CultureInfo.InvariantCulture, "background-color: rgb({0}, {1}, {2}, .1)", red, green, blue);
            })
            .ToList();
    }

    static string FormatAnomaly(double anomaly, UnitOfMeasure unitOfMeasure)
    {
        var sign = anomaly >= 0 ? "+" : string.Empty;
        return $"{sign}{anomaly.ToString("0.0", CultureInfo.InvariantCulture)}{Enums.UnitOfMeasureLabelShort(unitOfMeasure)}";
    }

    static string FormatValue(double value, UnitOfMeasure unitOfMeasure)
    {
        return $"{value.ToString("0.0", CultureInfo.InvariantCulture)}{Enums.UnitOfMeasureLabelShort(unitOfMeasure)}";
    }

    static string DataAdjustmentToString(DataAdjustment? da) => da.HasValue ? da.Value.ToString() : "none";
}