@using Blazorise
@using ClimateExplorer.Core
@using ClimateExplorer.Core.Model
@using ClimateExplorer.Core.ViewModel
@using ClimateExplorer.Web.UiModel
@using System.Globalization
@using ClimateExplorer.WebApiClient.Services
@using static ClimateExplorer.Core.Enums

@if (AvailableDataTypes.Count > 0)
{
    <Fields>
        <Field>
            <FieldLabel>Data type</FieldLabel>
            <FieldBody>
                <Select TValue="DataType"
                        Value="@SelectedDataType"
                        ValueChanged="@OnDataTypeChanged"
                        Size="Size.Small">
                    @foreach (var dt in AvailableDataTypes)
                    {
                        <SelectItem Value="@dt">@ChartSeriesDefinition.MapDataTypeToFriendlyName(dt)</SelectItem>
                    }
                </Select>
            </FieldBody>
        </Field>
        @if (AvailableDataAdjustments.Count > 1)
        {
            <Field>
                <FieldLabel>Adjustment</FieldLabel>
                <FieldBody>
                    <Select TValue="string"
                            Value="@DataAdjustmentToString(SelectedDataAdjustment)"
                            ValueChanged="@OnDataAdjustmentStringChanged"
                            Size="Size.Small">
                        @foreach (var da in AvailableDataAdjustments)
                        {
                            <SelectItem Value="@DataAdjustmentToString(da)">@(da.HasValue ? da.Value.ToString() : "None")</SelectItem>
                        }
                    </Select>
                </FieldBody>
            </Field>
        }
        <Field>
            <FieldLabel>Month</FieldLabel>
            <FieldBody>
                <Select TValue="int"
                        Value="@SelectedMonth"
                        ValueChanged="@OnMonthChanged"
                        Size="Size.Small">
                    <SelectItem Value="0">All months</SelectItem>
                    @for (int m = 1; m <= 12; m++)
                    {
                        var monthNum = m;
                        <SelectItem Value="@monthNum">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(monthNum)</SelectItem>
                    }
                </Select>
            </FieldBody>
        </Field>
        <Field>
            <FieldLabel>Order</FieldLabel>
            <FieldBody>
                <Select TValue="bool"
                        Value="@Ascending"
                        ValueChanged="@OnAscendingChanged"
                        Size="Size.Small">
                    <SelectItem Value="false">Highest first</SelectItem>
                    <SelectItem Value="true">Lowest first</SelectItem>
                </Select>
            </FieldBody>
        </Field>
        <Field ColumnSize="ColumnSize.IsAuto">
            <FieldLabel>Count</FieldLabel>
            <FieldBody>
                <Select TValue="int"
                        Value="@Count"
                        ValueChanged="@OnCountChanged"
                        Size="Size.Small">
                    <SelectItem Value="10">10</SelectItem>
                    <SelectItem Value="20">20</SelectItem>
                    <SelectItem Value="50">50</SelectItem>
                </Select>
            </FieldBody>
        </Field>
    </Fields>
}

@if (ClimateRecords is not null && ClimateRecords.Any())
{
    <Table Striped>
        <TableHeader>
            <TableRow>
                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>#</Strong></TableHeaderCell>
                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Day/Month</Strong></TableHeaderCell>
                <TableHeaderCell TextAlignment="TextAlignment.Center"><Strong>Year</Strong></TableHeaderCell>
                <TableHeaderCell TextAlignment="TextAlignment.End"><Strong>Value</Strong></TableHeaderCell>
            </TableRow>
        </TableHeader>
        <TableBody>
            @{
                var rank = 1;
                foreach (var record in ClimateRecords)
                {
                    var currentRank = rank;
                    <TableRow>
                        <TableRowCell TextAlignment="TextAlignment.Center">@currentRank</TableRowCell>
                        <TableRowCell>
                            @if (record.Day.HasValue)
                            {
                                <span class="secondary-text">@record.Day @CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(record.Month)</span>
                            }
                            else
                            {
                                <span class="secondary-text">@CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(record.Month)</span>
                            }
                            </TableRowCell>
                        <TableRowCell>
                            @record.Year
                        </TableRowCell>
                        <TableRowCell TextAlignment="TextAlignment.End">@record.Value@Enums.UnitOfMeasureLabelShort(record.UnitOfMeasure)</TableRowCell>
                    </TableRow>
                    rank++;
                }
            }
        </TableBody>
    </Table>
}
else if (ClimateRecords is not null)
{
    <p>No records found for the selected filters.</p>
}

@code {
    [Inject]
    public IDataService? DataService { get; set; }

    [Parameter]
    public Location? Location { get; set; }

    [PersistentState]
    public IEnumerable<ClimateRecord>? ClimateRecords { get; set; }

    List<DataType> AvailableDataTypes { get; set; } = [];
    List<DataAdjustment?> AvailableDataAdjustments { get; set; } = [];
    List<MeasurementDefinitionViewModel> LocationMeasurements { get; set; } = [];

    DataType SelectedDataType { get; set; } = DataType.TempMax;
    DataAdjustment? SelectedDataAdjustment { get; set; } = DataAdjustment.Adjusted;
    int SelectedMonth { get; set; } = 0;
    bool Ascending { get; set; } = false;
    int Count { get; set; } = 10;

    Guid? InternalLocationId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Location is null || Location.Id == InternalLocationId)
        {
            return;
        }

        InternalLocationId = Location.Id;
        await LoadAvailableOptions();
        await LoadRecords();
    }

    async Task LoadAvailableOptions()
    {
        var dataSetDefinitions = await DataService!.GetDataSetDefinitions();
        LocationMeasurements = dataSetDefinitions
            .Where(x => x.LocationIds != null && x.LocationIds.Contains(Location!.Id))
            .SelectMany(x => x.MeasurementDefinitions!)
            .Where(x => x.DataResolution == DataResolution.Daily || x.DataResolution == DataResolution.Monthly)
            .ToList();

        AvailableDataTypes = LocationMeasurements
            .Select(x => x.DataType)
            .Distinct()
            .ToList();

        if (AvailableDataTypes.Contains(DataType.TempMax))
            SelectedDataType = DataType.TempMax;
        else if (AvailableDataTypes.Any())
            SelectedDataType = AvailableDataTypes.First();

        UpdateAvailableAdjustments();
    }

    void UpdateAvailableAdjustments()
    {
        AvailableDataAdjustments = LocationMeasurements
            .Where(x => x.DataType == SelectedDataType)
            .Select(x => x.DataAdjustment)
            .Distinct()
            .ToList();

        if (AvailableDataAdjustments.Contains(DataAdjustment.Adjusted))
            SelectedDataAdjustment = DataAdjustment.Adjusted;
        else if (AvailableDataAdjustments.Any())
            SelectedDataAdjustment = AvailableDataAdjustments.First();
        else
            SelectedDataAdjustment = null;
    }

    async Task LoadRecords()
    {
        if (Location is null) return;
        ClimateRecords = await DataService!.GetClimateRecords(Location.Id, SelectedDataType, SelectedDataAdjustment, Ascending, Count, SelectedMonth == 0 ? null : SelectedMonth);
    }

    async Task OnDataTypeChanged(DataType value)
    {
        SelectedDataType = value;
        UpdateAvailableAdjustments();
        await LoadRecords();
    }

    async Task OnDataAdjustmentStringChanged(string value)
    {
        SelectedDataAdjustment = value == "none" ? null : Enum.Parse<DataAdjustment>(value);
        await LoadRecords();
    }

    async Task OnMonthChanged(int value)
    {
        SelectedMonth = value;
        await LoadRecords();
    }

    async Task OnAscendingChanged(bool value)
    {
        Ascending = value;
        await LoadRecords();
    }

    async Task OnCountChanged(int value)
    {
        Count = value;
        await LoadRecords();
    }

    static string DataAdjustmentToString(DataAdjustment? da) => da.HasValue ? da.Value.ToString() : "none";
}
