@page "/blog/{slug}"
@attribute [ExcludeFromInteractiveRouting]
@using ClimateExplorer.Web.Blog
@inject BlogService BlogService
@inject NavigationManager NavigationManager

@if (_post is null)
{
    <PageTitle>Post not found – ClimateExplorer</PageTitle>
    <div class="text-content">
        <h1>Post not found</h1>
        <p>The blog post you are looking for does not exist.</p>
        <a href="/blog">← Back to blog</a>
    </div>
}
else
{
    <PageTitle>@_post.Title – ClimateExplorer</PageTitle>
    <HeadContent>
        <meta name="description" content="@_post.Excerpt" />
        <link rel="canonical" href="https://climateexplorer.net/blog/@_post.Slug" />
        <meta property="og:title" content="@_post.Title" />
        <meta property="og:url" content="https://climateexplorer.net/blog/@_post.Slug" />
        <meta property="og:type" content="article" />
        <meta property="og:site_name" content="ClimateExplorer" />
        @if (!string.IsNullOrEmpty(_post.Excerpt))
        {
            <meta property="og:description" content="@_post.Excerpt" />
        }
    </HeadContent>

    <div class="text-content">
        <div class="post-meta">
            <time datetime="@_post.Date.ToString("yyyy-MM-dd")">@_post.Date.ToString("d MMMM yyyy")</time>
            @if (!string.IsNullOrEmpty(_post.Category))
            {
                <span class="post-category">@_post.Category</span>
            }
        </div>
        <h1>@_post.Title</h1>
        <article class="post-body">
            @((MarkupString)_post.HtmlContent)
        </article>
        <div class="back-link">
            <a href="/blog">← Back to blog</a>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private BlogPost? _post;

    protected override void OnParametersSet()
    {
        _post = Slug is null ? null : BlogService.GetPostBySlug(Slug);
    }
}
